; pool_size: 2
; abi_params: 4
; abi_return: i32
; name: multi_param_mixed

func @test(v1: i32, v2: i32, v3: i32, v4: i32) -> i32 {
    v5:i32 = iadd v1, v2
    v6:i32 = iadd v3, v4
    v7:i32 = iadd v5, v6
    return v7
}

