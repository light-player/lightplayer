; pool_size: 2
; abi_params: 0
; abi_return: i32
; name: spill_chain

func @test() -> i32 {
    v1:i32 = iconst.i32 1
    v2:i32 = iconst.i32 2
    v3:i32 = iconst.i32 3
    v4:i32 = iconst.i32 4
    v5:i32 = iadd v1, v4
    return v5
}

