; pool_size: 2
; abi_params: 1
; abi_return: i32
; import: f(i32) -> i32
; name: call_callee_saved

func @test(v1: i32) -> i32 {
    v2:i32 = iconst.i32 42
    v3:i32 = call @filetest::f(v1)
    v4:i32 = iadd v2, v3
    return v4
}

